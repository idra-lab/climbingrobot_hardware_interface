<!-- alpine_low_level_bringup.launch -->
<launch>

  <!-- Rope zero / odometry convention shared with the real controller. -->
  <arg name="left_home_offset_m"  default="0.0"/>
  <arg name="right_home_offset_m" default="0.53"/>
  <arg name="left_rope_sign"      default="1.0"/>
  <arg name="right_rope_sign"     default="-1.0"/>
  <arg name="left_rope_axis"      default="-x"/>
  <arg name="homing_test_delta_m" default="0.5"/>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- High-level controller pipeline params                      -->
  <!-- Letti da climbingrobot_controller2_real.py tramite /alpine -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <param name="/alpine/pipeline_position_then_jump_enabled" value="true"/>
  <param name="/alpine/pipeline_jump_mode" value="manual"/>
  <param name="/alpine/pipeline_landing_enabled" value="false"/>

  <!-- Position prima del salto: allunga entrambe le corde, quindi scende -->
  <param name="/alpine/prejump_drop_m" value="1.20"/>
  <param name="/alpine/prejump_position_tolerance_m" value="0.03"/>
  <param name="/alpine/prejump_position_timeout_s" value="20.0"/>
  <param name="/alpine/prejump_position_min_wait_s" value="0.50"/>
  <param name="/alpine/prejump_abort_on_timeout" value="true"/>

  <!-- Hold anti-strappo in position mode -->
  <param name="/alpine/post_homing_position_hold_s" value="0.50"/>
  <param name="/alpine/prejump_position_settle_after_reached_s" value="0.50"/>

  <!-- Sinusoide laterale finita dopo position e prima del jump -->
  <param name="/alpine/prejump_lateral_sine_enabled" value="true"/>
  <param name="/alpine/prejump_lateral_sine_amp_fy" value="0.60"/>
  <param name="/alpine/prejump_lateral_sine_freq_hz" value="1.0"/>
  <param name="/alpine/prejump_lateral_sine_duration_s" value="2.0"/>
  <param name="/alpine/prejump_lateral_sine_ramp_s" value="0.25"/>

  <!-- RViz/debug corde -->
  <param name="/alpine/rviz_use_measured_rope_joints" value="true"/>
  <param name="/alpine/rviz_show_rope_length_text" value="true"/>

  <!-- Real ALPINE geometry used by odometry and, through /alpine params,
       also by climbingrobot_controller2_real.py. -->
  <rosparam param="/alpine/anchor_left_xyz">[0.45, 0.0, 2.50]</rosparam>
  <rosparam param="/alpine/anchor_right_xyz">[0.45, 0.65, 2.50]</rosparam>
  <rosparam param="/alpine/body_origin_from_left_attachment_xyz">[0.0, 0.0, -0.55]</rosparam>
  <rosparam param="/alpine/right_attachment_from_left_body_xyz">[0.0, -0.55, 0.0]</rosparam>
  <param name="/alpine/left_home_offset_m"  value="$(arg left_home_offset_m)"/>
  <param name="/alpine/right_home_offset_m" value="$(arg right_home_offset_m)"/>
  <param name="/alpine/left_rope_sign"      value="$(arg left_rope_sign)"/>
  <param name="/alpine/right_rope_sign"     value="$(arg right_rope_sign)"/>
  <param name="/alpine/left_rope_axis"      value="$(arg left_rope_axis)"/>
  <param name="/alpine/homing_test_delta_m" value="$(arg homing_test_delta_m)"/>

  <!-- Single global propellers config used by:
       - dongle_node.py (low-level startup commands)
       - climbingrobot_controller2_real.py (high-level wrench limits / startup flags)
  -->
  <rosparam command="load"
            file="$(find climbingrobot_hardware_interface)/config/propellers.yaml"/>

  <!-- Common winch position gains -->
  <rosparam command="load"
            file="$(find climbingrobot_hardware_interface)/config/winch_position_gains.yaml"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Left Winch telemetry node -->
  <node pkg="climbingrobot_hardware_interface"
        type="telemetry_node.py"
        name="telemetry_node_left"
        output="screen">

    <param name="side"        value="left"/>
    <param name="serial_port" value="/dev/serial/by-id/usb-1a86_USB_Single_Serial_5970047399-if00"/>

    <param name="config_path"
           value="$(find climbingrobot_hardware_interface)/config/arganelloTelemetry.json"/>
    <param name="debug_mode" value="true"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Right Winch telemetry node -->
 <node pkg="climbingrobot_hardware_interface"
        type="telemetry_node.py"
        name="telemetry_node_right"
        output="screen">

    <param name="side"        value="right"/>
    <param name="serial_port" value="/dev/serial/by-id/usb-1a86_USB_Single_Serial_5970046081-if00"/>

    <param name="config_path"
           value="$(find climbingrobot_hardware_interface)/config/arganelloTelemetry.json"/>
    <param name="debug_mode" value="true"/>
  </node>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Alpine Dongle node                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
 <!-- <node pkg="climbingrobot_hardware_interface"
        type="dongle_node.py"
        name="dongle_node"
        output="screen">

    <param name="serial_port"  value="/dev/serial/by-id/usb-1a86_USB_Single_Serial_5A7A010904-if00"/>
    <param name="baud"         value="1000000"/>
    <param name="poll_rate"    value="100.0"/>  -->

    <!-- Apply low-level propeller config (deadbands, PID, umax/yumax, startup flags)
         by reading /alpine/propellers/low_level from the global parameter server. -->
  <!--  <param name="apply_propeller_config_on_start" value="true"/>
    <param name="apply_propeller_config_delay_s"  value="1.0"/>
    <param name="propeller_low_level_ns"          value="/alpine/propellers/low_level"/>
  </node>   -->


   <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Alpine Body serial node: USB diretto, no ESP-NOW/dongle     -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node pkg="climbingrobot_hardware_interface"
        type="dongle_node.py"
        name="body_serial_node"
        output="screen">

  <rosparam command="load"
            file="$(find climbingrobot_hardware_interface)/config/propellers.yaml"/>

    <!-- SOSTITUIRE con la seriale by-id del body collegato via USB -->
     <param name="serial_port"
         value="/dev/serial/by-id/usb-1a86_USB_Single_Serial_5970047301-if00"/>

    <param name="baud"      value="115200"/>  <!--1000000-->
    <param name="poll_rate" value="100.0"/>

    <param name="rx_watchdog_timeout_s" value="0.0"/>

  <!-- Questo fa partire automaticamente la modalità ROS nel firmware -->
    <param name="body_serial_mode_on_start" value="true"/>
    <param name="body_serial_mode_cmd" value="ros on"/>

    <param name="serial_settle_delay_s" value="1.5"/>
    <param name="apply_propeller_config_on_start" value="true"/>
    <param name="apply_propeller_config_delay_s"  value="2.0"/>
    <param name="propeller_low_level_ns"          value="/alpine/propellers/low_level"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Alpine odometry + body telemetry                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node pkg="climbingrobot_hardware_interface"
        type="alpine_odometry_node.py"
        name="alpine_odometry_node"
        output="screen">

    <rosparam command="load"
              file="$(find climbingrobot_hardware_interface)/config/alpine_odometry.yaml"/>

    <!-- Explicit overrides, so launch args win over YAML defaults. -->
    <param name="left_home_offset_m"  value="$(arg left_home_offset_m)"/>
    <param name="right_home_offset_m" value="$(arg right_home_offset_m)"/>
    <param name="left_rope_sign"      value="$(arg left_rope_sign)"/>
    <param name="right_rope_sign"     value="$(arg right_rope_sign)"/>
    <param name="left_rope_axis"      value="$(arg left_rope_axis)"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Jump node                                                   -->
  <!-- /alpine/jump: manual safe jump, valves + local rope forces  -->
  <!-- /alpine_body/command: optimized Fleg -> valves only         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node pkg="climbingrobot_hardware_interface"
        type="jump.py"
        name="jump_node"
        output="screen">

    <rosparam command="load"
              file="$(find climbingrobot_hardware_interface)/config/jump_params.yaml"/>
  </node>

</launch>